+namespace {
+constexpr char kSocketPath[] = "/run/pluto/appload-control.sock";
+constexpr char kRuntimeDir[] = "/run/pluto";
+constexpr char kScreenshotDir[] = "/run/pluto/screenshots";
+constexpr char kAckDir[] = "/run/pluto/acks";
+constexpr char kAppLoadRoot[] = "/home/root/xovi/exthome/appload";
+constexpr char kDefaultPath[] = "/home/root/pluto/state/default-app";
+constexpr qsizetype kMaxPacket = 32768;
+constexpr int kLaunchTimeoutMs = 3000;
+constexpr int kLaunchPollIntervalMs = 25;
+
+bool isStrictUtf8(const QByteArray &bytes) {
+    const auto *p = reinterpret_cast<const unsigned char *>(bytes.constData());
+    qsizetype i = 0;
+    while(i < bytes.size()) {
+        const unsigned char c = p[i++];
+        if(c <= 0x7f) continue;
+        int more = 0;
+        unsigned int value = 0;
+        if((c & 0xe0) == 0xc0) { more = 1; value = c & 0x1f; if(value < 2) return false; }
+        else if((c & 0xf0) == 0xe0) { more = 2; value = c & 0x0f; }
+        else if((c & 0xf8) == 0xf0) { more = 3; value = c & 0x07; }
+        else return false;
+        if(i + more > bytes.size()) return false;
+        for(int n = 0; n < more; ++n) {
+            const unsigned char d = p[i++];
+            if((d & 0xc0) != 0x80) return false;
+            value = (value << 6) | (d & 0x3f);
+        }
+        if((more == 2 && value < 0x800) || (more == 3 && value < 0x10000) ||
+           value > 0x10ffff || (value >= 0xd800 && value <= 0xdfff)) return false;
+    }
+    return true;
+}
+
+bool printableToken(const QString &value) {
+    if(value.isEmpty() || value.size() > 128) return false;
+    for(const QChar c : value) {
+        const ushort u = c.unicode();
+        if(u < 0x21 || u > 0x7e) return false;
+    }
+    return true;
+}
+
+PlutoControlServer::ActionResult failure(const QString &code, const QString &message) {
+    PlutoControlServer::ActionResult result;
+    result.code = code;
+    result.message = message;
+    return result;
+}
+
+PlutoControlServer::ActionResult success(const QJsonObject &object = {}) {
+    PlutoControlServer::ActionResult result;
+    result.ok = true;
+    result.result = object;
+    return result;
+}
+}
+
+void ensurePlutoControlServer(AppLoadLauncher *launcher) {
+    if(!launcher) return;
+    QCoreApplication *application = QCoreApplication::instance();
+    if(!application) return;
+    auto create = [launcher, application] {
+        static QPointer<PlutoControlServer> mainThreadServer;
+        if(mainThreadServer) return;
+        mainThreadServer = new PlutoControlServer(launcher, application);
+        if(!mainThreadServer->start()) {
+            qWarning() << "Pluto AppLoad control disabled:" << mainThreadServer->errorString();
+            mainThreadServer->deleteLater();
+            mainThreadServer = nullptr;
+        }
+    };
+    if(QThread::currentThread() == application->thread()) create();
+    else QMetaObject::invokeMethod(application, create, Qt::QueuedConnection);
+}
+
+PlutoControlServer::PlutoControlServer(AppLoadLauncher *launcher, QObject *parent)
+    : QObject(parent), launcher_(launcher) {
+    connect(launcher_, &AppLoadLauncher::applicationLaunched, this,
+            [this](const QString &entryId, qint64 pid) {
+        static const QString prefix = QStringLiteral("external::pluto-");
+        if(pid <= 0 || !entryId.startsWith(prefix)) return;
+        const QString appId = entryId.mid(prefix.size());
+        QString reason;
+        if(!verifyManagedEntry(appId, entryId, &reason)) return;
+        for(auto it = apps_.begin(); it != apps_.end(); ++it) it->visible = false;
+        apps_.insert(appId, ManagedApp {appId, entryId, pid, true});
+    });
+    connect(launcher_, &AppLoadLauncher::applicationStopped, this,
+            [this](const QString &entryId, qint64 pid) {
+        for(auto it = apps_.begin(); it != apps_.end();) {
+            if(it->entryId == entryId && it->pid == pid) it = apps_.erase(it);
+            else ++it;
+        }
+    });
+}
+
+PlutoControlServer::~PlutoControlServer() {
+    if(listenFd_ >= 0) close(listenFd_);
+    struct stat st {};
+    if(lstat(kSocketPath, &st) == 0 && S_ISSOCK(st.st_mode) && st.st_uid == 0)
+        unlink(kSocketPath);
+}
+
+QString PlutoControlServer::errorString() const { return error_; }
+
+bool PlutoControlServer::start() {
+    if(!QDir().mkpath(kRuntimeDir) || chmod(kRuntimeDir, 0700) != 0) {
+        error_ = QStringLiteral("cannot secure /run/pluto: %1").arg(strerror(errno));
+        return false;
+    }
+    struct stat existing {};
+    if(lstat(kSocketPath, &existing) == 0) {
+        if(!S_ISSOCK(existing.st_mode) || existing.st_uid != 0) {
+            error_ = QStringLiteral("refusing an untrusted stale control path");
+            return false;
+        }
+        if(unlink(kSocketPath) != 0) {
+            error_ = QStringLiteral("cannot remove stale control socket: %1").arg(strerror(errno));
+            return false;
+        }
+    } else if(errno != ENOENT) {
+        error_ = QStringLiteral("cannot inspect control socket: %1").arg(strerror(errno));
+        return false;
+    }
+
+    listenFd_ = socket(AF_UNIX, SOCK_SEQPACKET | SOCK_CLOEXEC, 0);
+    if(listenFd_ < 0) {
+        error_ = QStringLiteral("cannot create control socket: %1").arg(strerror(errno));
+        return false;
+    }
+    sockaddr_un address {};
+    address.sun_family = AF_UNIX;
+    static_assert(sizeof(kSocketPath) <= sizeof(address.sun_path));
+    memcpy(address.sun_path, kSocketPath, sizeof(kSocketPath));
+    const socklen_t length = static_cast<socklen_t>(offsetof(sockaddr_un, sun_path) + sizeof(kSocketPath));
+    if(bind(listenFd_, reinterpret_cast<sockaddr *>(&address), length) != 0 ||
+       chmod(kSocketPath, 0600) != 0 || listen(listenFd_, 8) != 0) {
+        error_ = QStringLiteral("cannot bind control socket: %1").arg(strerror(errno));
+        close(listenFd_);
+        listenFd_ = -1;
+        unlink(kSocketPath);
+        return false;
+    }
+    const int flags = fcntl(listenFd_, F_GETFL, 0);
+    if(flags < 0 || fcntl(listenFd_, F_SETFL, flags | O_NONBLOCK) != 0) {
+        error_ = QStringLiteral("cannot make control socket nonblocking: %1").arg(strerror(errno));
+        return false;
+    }
+    notifier_ = new QSocketNotifier(listenFd_, QSocketNotifier::Read, this);
+    connect(notifier_, &QSocketNotifier::activated, this,
+            [this](auto...) { acceptReady(); });
+    markerTimer_ = new QTimer(this);
+    markerTimer_->setInterval(50);
+    connect(markerTimer_, &QTimer::timeout, this, [this] { scanMarkers(); });
+    markerTimer_->start();
+    QTimer::singleShot(1500, this, [this] { launchDefault(); });
+    QDEBUG << "Pluto AppLoad control ready at" << kSocketPath;
+    return true;
+}
+
+void PlutoControlServer::acceptReady() {
+    for(;;) {
+        const int client = accept4(listenFd_, nullptr, nullptr, SOCK_CLOEXEC);
+        if(client < 0) {
+            if(errno == EINTR) continue;
+            if(errno == EAGAIN || errno == EWOULDBLOCK) return;
+            CERR << "Pluto control accept failed: " << strerror(errno) << std::endl;
+            return;
+        }
+        handleClient(client);
+        close(client);
+    }
+}
+
+void PlutoControlServer::handleClient(int clientFd) {
+    ucred credentials {};
+    socklen_t credentialLength = sizeof(credentials);
+    if(getsockopt(clientFd, SOL_SOCKET, SO_PEERCRED, &credentials, &credentialLength) != 0 ||
+       credentialLength != sizeof(credentials) || credentials.uid != 0) return;
+
+    timeval timeout {};
+    timeout.tv_sec = 1;
+    setsockopt(clientFd, SOL_SOCKET, SO_RCVTIMEO, &timeout, sizeof(timeout));
+    QByteArray bytes(kMaxPacket + 1, Qt::Uninitialized);
+    const ssize_t received = recv(clientFd, bytes.data(), bytes.size(), MSG_TRUNC);
+    QJsonObject response;
+    if(received <= 0 || received > kMaxPacket) {
+        response = dispatch({}, QString());
+    } else {
+        bytes.resize(received);
+        if(bytes.contains('\0') || !isStrictUtf8(bytes)) {
+            response = dispatch({}, QString());
+        } else {
+            QJsonParseError parseError;
+            const QJsonDocument document = QJsonDocument::fromJson(bytes, &parseError);
+            if(parseError.error != QJsonParseError::NoError || !document.isObject()) {
+                response = dispatch({}, QString());
+            } else {
+                const QJsonObject request = document.object();
+                response = dispatch(request, request.value("requestId").toString());
+            }
+        }
+    }
+    const QByteArray encoded = QJsonDocument(response).toJson(QJsonDocument::Compact);
+    send(clientFd, encoded.constData(), encoded.size(), MSG_NOSIGNAL);
+}
+
+QJsonObject PlutoControlServer::dispatch(const QJsonObject &request, const QString &requestId) {
+    ActionResult action;
+    if(request.isEmpty()) action = failure("bad-request", "request is not a valid UTF-8 JSON object");
+    else if(request.value("schema").toInt(-1) != 1) action = failure("bad-schema", "unsupported control schema");
+    else if(!printableToken(requestId)) action = failure("bad-request-id", "requestId must be printable ASCII");
+    else action = perform(request);
+
+    QJsonObject response {{"schema", 1}, {"requestId", requestId}, {"ok", action.ok}};
+    if(action.ok) response.insert("result", action.result);
+    else response.insert("error", QJsonObject {{"code", action.code}, {"message", action.message}});
+    return response;
+}
+
+PlutoControlServer::ActionResult PlutoControlServer::perform(const QJsonObject &request) {
+    const QString action = request.value("action").toString();
+    if(action == "ping") return success({{"protocol", 1}, {"serverVersion", "pluto-1"}});
+    if(action == "reload") {
+        const int count = appload::library::loadApplications();
+        return success({{"entryCount", count}});
+    }
+    if(action == "launch") {
+        const QString appId = request.value("appId").toString();
+        const QString entryId = request.value("entryId").toString();
+        if(!request.value("replace").isBool()) return failure("bad-args", "launch requires replace");
+        return launch(appId, entryId, request.value("replace").toBool());
+    }
+    if(action == "stop") return stop(request.value("appId").toString());
+    if(action == "stopAll") {
+        if(request.value("scope").toString() != "pluto") return failure("bad-args", "stopAll scope must be pluto");
+        return stopAll();
+    }
+    if(action == "setDefault") {
+        const QJsonValue value = request.value("appId");
+        if(!value.isNull() && !value.isString()) return failure("bad-args", "default app must be a string or null");
+        const QString appId = value.isNull() ? QString() : value.toString();
+        QString reason;
+        if(!appId.isEmpty() && !verifyManagedEntry(appId, entryIdFor(appId), &reason))
+            return failure("not-found", reason);
+        if(!writeDefault(appId, &reason)) return failure("io", reason);
+        return success({{"defaultApp", appId.isEmpty() ? QJsonValue(QJsonValue::Null) : QJsonValue(appId)}});
+    }
+    if(action == "status") {
+        appload::library::loadApplications();
+        reconcileManagedApps();
+        QJsonArray records;
+        for(const ManagedApp &app : apps_) {
+            records.append(QJsonObject {{"appId", app.appId}, {"entryId", app.entryId},
+                                        {"pid", app.pid}, {"running", launcher_->pidFor(app.entryId) == app.pid},
+                                        {"visible", app.visible}});
+        }
+        const QString configured = defaultApp();
+        return success({{"defaultApp", configured.isEmpty() ? QJsonValue(QJsonValue::Null) : QJsonValue(configured)},
+                        {"apps", records}});
+    }
+    if(action == "screenshot")
+        return screenshot(request.value("appId"), request.value("surface").toString());
+    return failure("unknown-action", "unknown control action");
+}
+
+bool PlutoControlServer::validAppId(const QString &appId) const {
+    static const QRegularExpression pattern(QStringLiteral("^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"));
+    return appId.contains('.') && pattern.match(appId).hasMatch() && !appId.contains("..") &&
+           !appId.endsWith('.') && !appId.startsWith('.');
+}
+
+QString PlutoControlServer::entryIdFor(const QString &appId) const {
+    return QStringLiteral("external::pluto-") + appId;
+}
+
+bool PlutoControlServer::verifyManagedEntry(const QString &appId, const QString &entryId,
+                                            QString *reason) const {
+    if(!validAppId(appId) || entryId != entryIdFor(appId)) {
+        *reason = QStringLiteral("application identity is invalid");
+        return false;
+    }
+    const QString leaf = entryId.mid(QStringLiteral("external::").size());
+    const QString path = QString::fromLatin1(kAppLoadRoot) + '/' + leaf + "/external.manifest.json";
+    const QFileInfo info(path);
+    if(!info.exists() || !info.isFile() || info.isSymLink() || info.ownerId() != 0) {
+        *reason = QStringLiteral("managed AppLoad manifest is missing or untrusted");
+        return false;
+    }
+    QFile file(path);
+    if(!file.open(QIODevice::ReadOnly) || file.size() > 65536) {
+        *reason = QStringLiteral("managed AppLoad manifest cannot be read");
+        return false;
+    }
+    QJsonParseError parseError;
+    const QJsonDocument document = QJsonDocument::fromJson(file.readAll(), &parseError);
+    const QJsonObject root = document.object();
+    const QJsonObject pluto = root.value("pluto").toObject();
+    if(parseError.error != QJsonParseError::NoError || !document.isObject() ||
+       pluto.value("schema").toInt(-1) != 1 || !pluto.value("managed").toBool() ||
+       pluto.value("appId").toString() != appId) {
+        *reason = QStringLiteral("AppLoad manifest is not owned by Pluto");
+        return false;
+    }
+    if(appload::library::getExternals().find(entryId) == appload::library::getExternals().end()) {
+        *reason = QStringLiteral("application is not installed in AppLoad");
+        return false;
+    }
+    return true;
+}
+
+void PlutoControlServer::reconcileManagedApps() {
+    static const QString prefix = QStringLiteral("external::pluto-");
+    const QString foregroundEntry = launcher_->foregroundEntry();
+    QHash<QString, ManagedApp> reconciled;
+    for(const QString &entryId : launcher_->trackedEntries()) {
+        if(!entryId.startsWith(prefix)) continue;
+        const qint64 pid = launcher_->pidFor(entryId);
+        if(pid <= 0) continue;
+        const QString appId = entryId.mid(prefix.size());
+        QString reason;
+        if(!verifyManagedEntry(appId, entryId, &reason)) continue;
+        const bool hasLiveWindow = launcher_->windowFor(entryId, pid) != nullptr;
+        reconciled.insert(appId, ManagedApp {
+            appId, entryId, pid, hasLiveWindow && entryId == foregroundEntry
+        });
+    }
+    apps_ = reconciled;
+}
+
+PlutoControlServer::ActionResult PlutoControlServer::launch(const QString &appId,
+                                                            const QString &entryId,
+                                                            bool replace) {
+    appload::library::loadApplications();
+    QString reason;
+    if(!verifyManagedEntry(appId, entryId, &reason)) return failure("not-found", reason);
+    reconcileManagedApps(); // Snapshot the prior foreground before replacement.
+
+    const auto commitLaunch = [&](qint64 committedPid) {
+        QStringList closeEntries;
+        if(replace) {
+            for(auto it = apps_.begin(); it != apps_.end(); ++it) {
+                if(it.key() != appId) closeEntries.append(it->entryId);
+            }
+        }
+        for(const QString &other : closeEntries) launcher_->stopApplication(other);
+        if(replace) apps_.clear();
+        for(auto it = apps_.begin(); it != apps_.end(); ++it) it->visible = false;
+        ManagedApp managed {appId, entryId, committedPid, true};
+        apps_.insert(appId, managed);
+        return success({{"pid", committedPid}, {"entryId", entryId}});
+    };
+    const auto awaitExactWindow = [&](qint64 expectedPid) {
+        bool ready = false;
+        QEventLoop joinLoop;
+        QTimer joinTimer;
+        QTimer joinPollTimer;
+        joinTimer.setSingleShot(true);
+        joinPollTimer.setInterval(kLaunchPollIntervalMs);
+        const auto check = [&] {
+            if(launcher_->pidFor(entryId) != expectedPid) {
+                joinLoop.quit();
+                return;
+            }
+            if(launcher_->windowFor(entryId, expectedPid)) {
+                ready = true;
+                joinLoop.quit();
+            }
+        };
+        const QMetaObject::Connection joinConnection = connect(
+            launcher_, &AppLoadLauncher::applicationLaunched, &joinLoop,
+            [&](const QString &launchedEntryId, qint64 launchedPid) {
+                if(launchedEntryId == entryId && launchedPid == expectedPid)
+                    check();
+            });
+        connect(&joinTimer, &QTimer::timeout, &joinLoop, &QEventLoop::quit);
+        connect(&joinPollTimer, &QTimer::timeout, &joinLoop, check);
+        check();
+        if(!ready && launcher_->pidFor(entryId) == expectedPid) {
+            joinTimer.start(kLaunchTimeoutMs);
+            joinPollTimer.start();
+            joinLoop.exec();
+        }
+        joinPollTimer.stop();
+        disconnect(joinConnection);
+        return ready ||
+               (launcher_->pidFor(entryId) == expectedPid &&
+                launcher_->windowFor(entryId, expectedPid));
+    };
+    const qint64 existingPid = launcher_->pidFor(entryId);
+    if(existingPid > 0) {
+        QString windowProblem;
+        if(!launcher_->activateTracked(entryId, &windowProblem)) {
+            if(!awaitExactWindow(existingPid)) {
+                launcher_->windowFor(entryId, existingPid, &windowProblem);
+                return failure(
+                    "launch-pending",
+                    QStringLiteral("tracked PID %1 did not publish its exact window: %2")
+                        .arg(existingPid).arg(windowProblem));
+            }
+            if(!launcher_->activateTracked(entryId, &windowProblem))
+                return failure(
+                    "launch-pending",
+                    QStringLiteral("tracked PID %1 window could not be activated: %2")
+                        .arg(existingPid).arg(windowProblem));
+        }
+        return commitLaunch(existingPid);
+    }
+
+    qint64 pid = -1;
+    QEventLoop launchLoop;
+    QTimer launchTimer;
+    QTimer launchPollTimer;
+    launchTimer.setSingleShot(true);
+    launchPollTimer.setInterval(kLaunchPollIntervalMs);
+    const auto acceptTrackedPid = [&]() {
+        const qint64 trackedPid = launcher_->pidFor(entryId);
+        if(trackedPid <= 0 || !launcher_->windowFor(entryId, trackedPid)) return false;
+        pid = trackedPid;
+        launchLoop.quit();
+        return true;
+    };
+    const QMetaObject::Connection launchedConnection = connect(
+        launcher_, &AppLoadLauncher::applicationLaunched, &launchLoop,
+        [&](const QString &launchedEntryId, qint64 launchedPid) {
+            if(launchedEntryId != entryId || launchedPid <= 0) return;
+            pid = launchedPid;
+            launchLoop.quit();
+        });
+    connect(&launchTimer, &QTimer::timeout, &launchLoop, &QEventLoop::quit);
+    connect(&launchPollTimer, &QTimer::timeout, &launchLoop,
+            [&] { acceptTrackedPid(); });
+    launcher_->launchApplication(entryId, {}, {}, false);
+    if(pid <= 0) {
+        acceptTrackedPid();
+        if(pid <= 0) {
+            launchTimer.start(kLaunchTimeoutMs);
+            launchPollTimer.start();
+            launchLoop.exec();
+        }
+    }
+    launchPollTimer.stop();
+    disconnect(launchedConnection);
+    if(pid <= 0)
+        return failure("launch-failed", "AppLoad did not publish a process PID");
+    QString windowProblem;
+    if(!launcher_->windowFor(entryId, pid, &windowProblem))
+        return failure("launch-failed",
+                       QStringLiteral("AppLoad did not publish a matching application window: ") +
+                           windowProblem);
+    return commitLaunch(pid);
+}
+
+PlutoControlServer::ActionResult PlutoControlServer::stop(const QString &appId) {
+    if(!validAppId(appId)) return failure("bad-args", "invalid application id");
+    appload::library::loadApplications();
+    reconcileManagedApps();
+    const auto it = apps_.find(appId);
+    if(it == apps_.end()) return success({{"stopped", false}});
+    const QString entryId = it->entryId;
+    launcher_->stopApplication(entryId);
+    apps_.remove(appId);
+    return success({{"stopped", true}});
+}
+
+PlutoControlServer::ActionResult PlutoControlServer::stopAll() {
+    appload::library::loadApplications();
+    reconcileManagedApps();
+    const QStringList ids = apps_.keys();
+    for(const QString &id : ids) launcher_->stopApplication(apps_.value(id).entryId);
+    apps_.clear();
+    return success({{"stopped", ids.size()}});
+}
+
+PlutoControlServer::ActionResult PlutoControlServer::screenshot(const QJsonValue &appIdValue,
+                                                                const QString &surface) {
+    if(surface != "logical" && surface != "post-dither") return failure("bad-args", "unsupported screenshot surface");
+    appload::library::loadApplications();
+    reconcileManagedApps();
+    QString appId;
+    if(appIdValue.isString()) appId = appIdValue.toString();
+    else if(!appIdValue.isNull() && !appIdValue.isUndefined()) return failure("bad-args", "screenshot appId must be a string or null");
+    if(appId.isEmpty()) {
+        for(const ManagedApp &candidate : apps_) if(candidate.visible) { appId = candidate.appId; break; }
+    }
+    const auto it = apps_.constFind(appId);
+    if(it == apps_.cend()) return failure("not-running", "no matching Pluto application is visible");
+    QString windowProblem;
+    QObject *window = launcher_->windowFor(it->entryId, it->pid, &windowProblem);
+    if(!window)
+        return failure("not-running",
+                       QStringLiteral("application window is unavailable: ") + windowProblem);
+    if(!QDir().mkpath(kScreenshotDir) || chmod(kScreenshotDir, 0700) != 0)
+        return failure("io", "cannot secure screenshot directory");
+    const QString path = QString::fromLatin1(kScreenshotDir) + "/shot-" +
+                         QUuid::createUuid().toString(QUuid::WithoutBraces) + ".png";
+    const int placeholder = open(path.toLocal8Bit().constData(), O_CREAT | O_EXCL | O_WRONLY | O_CLOEXEC, 0600);
+    if(placeholder < 0) return failure("io", "cannot create screenshot file");
+    close(placeholder);
+    QVariant saved;
+    const bool invoked = QMetaObject::invokeMethod(window, "plutoScreenshot", Qt::DirectConnection,
+                                                    Q_RETURN_ARG(QVariant, saved),
+                                                    Q_ARG(QVariant, QVariant(path)));
+    if(!invoked || !saved.toBool()) {
+        QFile::remove(path);
+        return failure("screenshot-failed", "QTFB image is not ready");
+    }
+    chmod(path.toLocal8Bit().constData(), 0600);
+    QFile file(path);
+    const QFileInfo info(path);
+    if(!info.isFile() || info.isSymLink() || info.ownerId() != 0 || !file.open(QIODevice::ReadOnly)) {
+        QFile::remove(path);
+        return failure("io", "screenshot output is untrusted");
+    }
+    const QByteArray bytes = file.readAll();
+    const QString hash = QString::fromLatin1(QCryptographicHash::hash(bytes, QCryptographicHash::Sha256).toHex());
+    return success({{"path", path}, {"bytes", bytes.size()}, {"sha256", hash}});
+}
+
+QString PlutoControlServer::defaultApp() const {
+    QFile file(kDefaultPath);
+    if(!file.open(QIODevice::ReadOnly)) return {};
+    return QString::fromUtf8(file.read(256)).trimmed();
+}
+
+bool PlutoControlServer::writeDefault(const QString &appId, QString *reason) const {
+    const QFileInfo info(kDefaultPath);
+    if(!QDir().mkpath(info.dir().path())) {
+        *reason = QStringLiteral("cannot create default-app directory");
+        return false;
+    }
+    if(appId.isEmpty()) {
+        if(QFile::exists(kDefaultPath) && !QFile::remove(kDefaultPath)) {
+            *reason = QStringLiteral("cannot clear default app");
+            return false;
+        }
+        return true;
+    }
+    QSaveFile file(kDefaultPath);
+    if(!file.open(QIODevice::WriteOnly) || file.write(appId.toUtf8() + '\n') < 0 || !file.commit()) {
+        *reason = QStringLiteral("cannot persist default app");
+        return false;
+    }
+    QFile::setPermissions(kDefaultPath, QFileDevice::ReadOwner | QFileDevice::WriteOwner);
+    return true;
+}
+
+void PlutoControlServer::launchDefault() {
+    const QString appId = defaultApp();
+    if(appId.isEmpty()) return;
+    const ActionResult result = launch(appId, entryIdFor(appId), true);
+    if(!result.ok) CERR << "Pluto default launch refused: " << result.message.toStdString() << std::endl;
+}
+
+void PlutoControlServer::scanMarkers() {
+    const QStringList names {QStringLiteral("launch"), QStringLiteral("home"), QStringLiteral("stock")};
+    for(const QString &name : names) consumeMarker(QString::fromLatin1(kRuntimeDir) + '/' + name, name);
+    const QDir appsDir(QString::fromLatin1(kRuntimeDir) + "/apps");
+    for(const QString &leaf : appsDir.entryList(QDir::Dirs | QDir::NoDotAndDotDot)) {
+        for(const QString &name : names) consumeMarker(appsDir.filePath(leaf + '/' + name), name);
+    }
+}
+
+void PlutoControlServer::consumeMarker(const QString &path, const QString &kind) {
+    struct stat st {};
+    const QByteArray native = QFile::encodeName(path);
+    if(lstat(native.constData(), &st) != 0) return;
+    if(!S_ISREG(st.st_mode) || st.st_uid != 0 || (st.st_mode & 022) != 0) {
+        QFile::remove(path);
+        return;
+    }
+    const QString nonce = QUuid::createUuid().toString(QUuid::WithoutBraces);
+    const QString claimed = path + ".processing-" + nonce;
+    if(!QFile::rename(path, claimed)) return;
+    QFile marker(claimed);
+    QString appId;
+    if(marker.open(QIODevice::ReadOnly)) appId = QString::fromUtf8(marker.read(256)).trimmed();
+    ActionResult result;
+    if(kind == "launch") result = launch(appId, entryIdFor(appId), true);
+    else if(kind == "home") result = launch(QStringLiteral("dev.pluto.launcher"), entryIdFor(QStringLiteral("dev.pluto.launcher")), true);
+    else result = stopAll();
+    QFile::remove(claimed);
+
+    if(QDir().mkpath(kAckDir)) {
+        chmod(kAckDir, 0700);
+        QSaveFile ack(QString::fromLatin1(kAckDir) + '/' + kind + '-' + nonce + ".json");
+        if(ack.open(QIODevice::WriteOnly)) {
+            QJsonObject object {{"ok", result.ok}, {"action", kind}};
+            if(result.ok) object.insert("result", result.result);
+            else object.insert("error", QJsonObject {{"code", result.code}, {"message", result.message}});
+            ack.write(QJsonDocument(object).toJson(QJsonDocument::Compact));
+            ack.commit();
+        }
+    }
+}
