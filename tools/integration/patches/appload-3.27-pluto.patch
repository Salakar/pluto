+    qint64 pidFor(const QString &id) const {
+        const auto it = _processes.constFind(id);
+        return it == _processes.cend() ? -1 : it->pid;
+    }
+    QObject *windowFor(const QString &id, qint64 expectedPid,
+                       QString *problem = nullptr) const {
+        const auto it = _processes.constFind(id);
+        if(it == _processes.cend()) {
+            if(problem) *problem = QStringLiteral("entry is not tracked");
+            return nullptr;
+        }
+        if(it->pid <= 0 || it->pid != expectedPid) {
+            if(problem) {
+                *problem = QStringLiteral("PID mismatch: tracked=%1 expected=%2")
+                               .arg(it->pid).arg(expectedPid);
+            }
+            return nullptr;
+        }
+        QObject *window = it->window.data();
+        if(!window) {
+            if(problem) *problem = QStringLiteral("window publication is pending or destroyed");
+            return nullptr;
+        }
+        const QString windowId = window->property("appLoadId").toString();
+        if(windowId != id) {
+            if(problem) {
+                *problem = QStringLiteral("window id mismatch: actual=%1 expected=%2")
+                               .arg(windowId, id);
+            }
+            return nullptr;
+        }
+        const qint64 windowPid = window->property("appPid").toLongLong();
+        if(windowPid != expectedPid) {
+            if(problem) {
+                *problem = QStringLiteral("window PID mismatch: actual=%1 expected=%2")
+                               .arg(windowPid).arg(expectedPid);
+            }
+            return nullptr;
+        }
+        if(problem) problem->clear();
+        return window;
+    }
+    bool activateTracked(const QString &id, QString *problem = nullptr) {
+        const qint64 pid = pidFor(id);
+        QObject *window = windowFor(id, pid, problem);
+        if(!window) return false;
+        if(!window->property("fullscreen").toBool())
+            QMetaObject::invokeMethod(window, "maximize", Qt::DirectConnection);
+        window->setProperty("z", window->property("z").toReal() + 1.0);
+        _foregroundEntry = id;
+        return true;
+    }
+    QStringList trackedEntries() const { return _processes.keys(); }
+    QString foregroundEntry() const { return _foregroundEntry; }
+    void stopApplication(const QString &id) { emit requestStop(id); }
 signals:
     void requestLaunch(QString id, QVariantList args, QVariantMap env, bool window);
+    void requestStop(QString id);
+    void applicationLaunched(QString id, qint64 pid);
+    void applicationStopped(QString id, qint64 pid);
+
+private:
+    struct TrackedProcess {
+        qint64 pid = -1;
+        QPointer<QObject> window;
+        bool foregroundRequested = false;
+        quintptr windowToken = 0;
+    };
+
+    inline static AppLoadLauncher *_instance = nullptr;
+    QHash<QString, TrackedProcess> _processes;
+    QSet<QString> _launching;
+    QString _foregroundEntry;
 };
