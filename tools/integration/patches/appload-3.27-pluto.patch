+#pragma once
+
+#include <QHash>
+#include <QJsonObject>
+#include <QObject>
+#include <QPointer>
+#include <QString>
+
+class AppLoadLauncher;
+class QSocketNotifier;
+class QTimer;
+
+void ensurePlutoControlServer(AppLoadLauncher *launcher);
+
+class PlutoControlServer final : public QObject {
+public:
+    explicit PlutoControlServer(AppLoadLauncher *launcher, QObject *parent = nullptr);
+    ~PlutoControlServer() override;
+
+    bool start();
+    QString errorString() const;
+
+    struct ActionResult {
+        bool ok = false;
+        QJsonObject result;
+        QString code;
+        QString message;
+    };
+
+private:
+    struct ManagedApp {
+        QString appId;
+        QString entryId;
+        qint64 pid = -1;
+        bool visible = false;
+    };
+
+    void acceptReady();
+    void handleClient(int clientFd);
+    void scanMarkers();
+    void consumeMarker(const QString &path, const QString &kind);
+    void launchDefault();
+
+    QJsonObject dispatch(const QJsonObject &request, const QString &requestId);
+    ActionResult perform(const QJsonObject &request);
+    ActionResult launch(const QString &appId, const QString &entryId, bool replace);
+    ActionResult stop(const QString &appId);
+    ActionResult stopAll();
+    ActionResult screenshot(const QJsonValue &appIdValue, const QString &surface);
+
+    void reconcileManagedApps();
+    bool verifyManagedEntry(const QString &appId, const QString &entryId,
+                            QString *failure) const;
+    QString defaultApp() const;
+    bool writeDefault(const QString &appId, QString *failure) const;
+    QString entryIdFor(const QString &appId) const;
+    bool validAppId(const QString &appId) const;
+
+    AppLoadLauncher *launcher_;
+    int listenFd_ = -1;
+    QPointer<QSocketNotifier> notifier_;
+    QPointer<QTimer> markerTimer_;
+    QHash<QString, ManagedApp> apps_;
+    QString error_;
+};
